# Copy to `.env` in this directory (`humaine-swarm/`).
# Chainlit does NOT load `common-fe/.env` — use this file or `export` in your shell.

# --- JWKS / Keycloak TLS (header auth from embedded Common FE) ---
# If logs show SSL: CERTIFICATE_VERIFY_FAILED when fetching .../openid-connect/certs:
# Local dev only — disables TLS verification for that JWKS HTTP request only:
# KEYCLOAK_JWKS_SSL_VERIFY=false
# Preferred — PEM bundle for your Keycloak HTTPS issuer:
# KEYCLOAK_CA_BUNDLE=/path/to/ca-bundle.pem
